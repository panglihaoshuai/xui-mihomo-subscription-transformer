{
  "upstream": "http://127.0.0.1:2096",
  "default_policy": "smart",
  "paths": {
    "/clash/example": {
      "upstream_path": "/clash/REPLACE_WITH_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "smart"
    },
    "/clash/failover-example": {
      "upstream_path": "/clash/REPLACE_WITH_ANOTHER_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "resilient"
    }
  },
  "policies": {
    "smart": {
      "group_layout": "simple",
      "group_type": "url-test",
      "node_include": ".*",
      "health_check": {
        "url": "https://chatgpt.com/cdn-cgi/trace",
        "interval": 10,
        "timeout": 10000,
        "tolerance": 150,
        "lazy": false,
        "expected_status": 200,
        "max_failed_times": 1
      }
    },
    "resilient": {
      "group_layout": "simple",
      "group_type": "fallback",
      "node_exclude": "(?i)expired|disabled",
      "health_check": {
        "url": "https://chatgpt.com/cdn-cgi/trace",
        "interval": 30,
        "timeout": 10000,
        "lazy": false,
        "expected_status": 200,
        "max_failed_times": 1
      }
    }
  }
}
