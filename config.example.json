{
  "upstream": "http://127.0.0.1:2096",
  "default_policy": "user-smart",
  "paths": {
    "/clash/admin-example": {
      "upstream_path": "/clash/REPLACE_WITH_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "admin-smart"
    },
    "/clash/user-example": {
      "upstream_path": "/clash/REPLACE_WITH_ANOTHER_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "user-smart"
    }
  },
  "policies": {
    "admin-smart": {
      "group_layout": "simple",
      "group_type": "url-test",
      "health_check": {
        "url": "https://www.gstatic.com/generate_204",
        "interval": 10,
        "timeout": 5000,
        "tolerance": 100,
        "lazy": false,
        "expected_status": 204,
        "max_failed_times": 1
      }
    },
    "user-smart": {
      "group_layout": "simple",
      "group_type": "url-test",
      "node_exclude_types": ["ss"],
      "health_check": {
        "url": "https://www.gstatic.com/generate_204",
        "interval": 10,
        "timeout": 5000,
        "tolerance": 100,
        "lazy": false,
        "expected_status": 204,
        "max_failed_times": 1
      }
    }
  }
}
