{
  "upstream": "http://127.0.0.1:2096",
  "default_policy": "smart",
  "paths": {
    "/clash/example": {
      "upstream_path": "/clash/REPLACE_WITH_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "smart"
    },
    "/clash/failover-example": {
      "upstream_path": "/clash/REPLACE_WITH_ANOTHER_3XUI_SUBSCRIPTION_TOKEN",
      "policy": "resilient"
    }
  },
  "policies": {
    "smart": {
      "group_type": "url-test",
      "node_include": ".*",
      "health_check": {
        "url": "https://www.gstatic.com/generate_204",
        "interval": 10,
        "timeout": 5000,
        "tolerance": 100,
        "lazy": false,
        "expected_status": 204,
        "max_failed_times": 1
      },
      "service_groups": [
        {
          "name": "OPENAI",
          "group_type": "url-test",
          "domains": [
            "chatgpt.com",
            "openai.com",
            "oaistatic.com",
            "oaiusercontent.com",
            "oaistatsig.com",
            "openaimerge.com",
            "ct.sendgrid.net",
            "intercom.io",
            "intercomcdn.com",
            "workos.com",
            "workoscdn.com",
            "challenges.cloudflare.com",
            "humb.apple.com",
            "stripe.com",
            "sentry.io",
            "datadoghq.com",
            "imgix.net"
          ],
          "health_check": {
            "url": "https://chatgpt.com/cdn-cgi/trace",
            "interval": 60,
            "timeout": 10000,
            "tolerance": 150,
            "lazy": true,
            "expected_status": 200,
            "max_failed_times": 1
          }
        }
      ]
    },
    "resilient": {
      "group_type": "fallback",
      "node_exclude": "(?i)expired|disabled",
      "health_check": {
        "url": "https://www.gstatic.com/generate_204",
        "interval": 30,
        "timeout": 5000,
        "lazy": false,
        "expected_status": 204,
        "max_failed_times": 1
      }
    }
  }
}
